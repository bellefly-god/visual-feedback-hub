# Supabase Configuration
# Replace with your own Supabase project credentials

# Your Supabase project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anonymous (public) key
# This key is safe to expose in frontend code
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Enable Supabase Auth (set to "true" to use real authentication)
# When false, uses localStorage-based mock authentication for development
VITE_USE_SUPABASE_AUTH=false